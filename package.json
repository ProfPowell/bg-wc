{
  "name": "@profpowell/bg-wc",
  "version": "0.3.0",
  "description": "Theme-aware background web component: animated WebGL & Canvas2D backgrounds behind any HTML content.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/bg-wc.js",
  "module": "dist/bg-wc.js",
  "exports": {
    ".": "./dist/bg-wc.js",
    "./data-background": "./dist/data-background.js",
    "./data-bg": "./dist/data-background.js",
    "./presets/*": "./dist/presets/*.js"
  },
  "files": [
    "dist",
    "custom-elements.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProfPowell/bg-wc.git"
  },
  "homepage": "https://profpowell.github.io/bg-wc/",
  "keywords": [
    "background",
    "web-component",
    "custom-element",
    "webgl",
    "canvas",
    "shader",
    "particles",
    "vanilla-breeze"
  ],
  "author": "ProfPowell",
  "sideEffects": [
    "dist/bg-wc.js",
    "dist/data-background.js"
  ],
  "scripts": {
    "dev": "vite --config vite.site.config.js",
    "build": "vite build",
    "build:site": "vite build --config vite.site.config.js",
    "preview": "vite preview --config vite.site.config.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:node": "node --test test/*.mjs",
    "test:pack": "npm run build && node scripts/pack-smoke.mjs",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.{js,mjs}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.{js,mjs}\"",
    "analyze": "cem analyze",
    "cem:check": "cem analyze && git diff --exit-code custom-elements.json",
    "prepublishOnly": "npm run build && npm run analyze"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@profpowell/code-block": "^2.9.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "vanilla-breeze": "^0.1.3",
    "vite": "^7.3.3"
  },
  "customElements": "custom-elements.json",
  "dependencies": {
    "@profpowell/browser-window": "^1.4.7"
  }
}
